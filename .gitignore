test/fixtures/reference-tides.json
docs/PROJECT-STATUS.md

# Node
node_modules/

# Claude Code auto-memory
.claude/auto-memory/dirty-files

# Superpowers SDD scratch
.superpowers/

# Raw Marine Institute / OPW source CSVs (regenerate via scripts/build-mi.mjs;
# see that file's header for the erddap.marine.ie re-download instructions)
data/*.csv

# Raw GeoNames Ireland country dump (regenerate via scripts/build-places.mjs)
data/IE.zip
data/IE.txt

# Raw Natural Earth coastline (mainland) + OSi/Tailte Éireann islands (islands) — inputs to
# scripts/build-coastline.mjs. The coastline is re-downloaded by the script; the OSi islands
# file is a manual open-data download (see build-coastline.mjs header for the source URL).
data/ne-coastline-raw.geojson
data/osi-islands-raw.geojson

# Capacitor web assembly output (regenerate via `npm run build:www`)
www/

# Android build outputs / local machine config / generated web-copy — the core
# android/ Gradle project (gradlew, build.gradle, AndroidManifest.xml, etc.) IS
# committed; only generated-per-build artifacts are excluded here.
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/app/src/main/assets/public/
android/capacitor-cordova-android-plugins/

# Raw OSi low-water mark (272MB ungeneralised open data) — regional subset baked into data/low-water.json
data/osi-lowwater-raw.geojson
# Raw OSi national coast (mainland coastline, baked into data/ireland-outline.json)
data/osi-coast-raw.geojson
